if [ ${refreshLibrary} -eq 1 ]; then
    printf "Subject: Radarr Post Processing\n\n***Successfully processed***\n$(cat ${processed})\n\n***Failed***\n$(cat ${failLog})" | ssmtp ${toEmail}
    cat /dev/null > ${processed}
    cat /dev/null > ${failLog}

    curl -v -H "Authorization: MediaBrowser Token=${jellyfinKey}" -X POST ${jellyfinHost}/ScheduledTasks/Running/7738148ffcd07979c7ceb148e06b3aed
fi

rm ${lockFile}