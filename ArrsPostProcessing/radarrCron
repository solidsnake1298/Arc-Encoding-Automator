#!/bin/bash

## Required variables from cronEnv
## baseDir: Where all working files are stored.  Avoid storing anything except automation related files and folders.
## jellyfinHost: The Jellyfin instance that will be commanded to run a library scan.
## jellyfinKey: In the Jellyfin dashboard you will need to create an API key for this script to use.
## toEmail: The email address you wish to be notified.  Requires ssmtp be installed and setup.  Available for pretty much all distros.
## https://wiki.debian.org/sSMTP
## qsvAv1: The path for my qsvAv1 script.  Must provide full path in cronEnv file.
## failedDir: The directory that files that failed to encode correctly will be placed.  Most of the time the file is just bad,
## occasionally the file is just weird and my qsvAv1 script didn't handle it properly.

source cronEnv

radarrPPDir="${baseDir}/radarr"
english="${radarrPPDir}/englishToProcess"
anime="${radarrPPDir}/animeToProcess"
korean="${radarrPPDir}/koreanToProcess"
chinese="${radarrPPDir}/chineseToProcess"
spanish="${radarrPPDir}/spanishToProcess"
englishQueue="${radarrPPDir}/englishToProcessQueue"
animeQueue="${radarrPPDir}/animeToProcessQueue"
koreanQueue="${radarrPPDir}/koreanToProcessQueue"
chineseQueue="${radarrPPDir}/chineseToProcessQueue"
spanishQueue="${radarrPPDir}/spanishToProcessQueue"
processed="${radarrPPDir}/processed"
scratchDir="${baseDir}/radarrScratchDir"
failLog="${radarrPPDir}/failed"
refreshLibrary=0
lockFile="${radarrPPDir}/cron.lock"

if [[ -f "${lockFile}" ]]; then
    exit 0
else
    touch ${lockFile}
fi

if [ -s "${animeQueue}" ]; then
    cp -p ${animeQueue} ${anime}
    cat /dev/null > ${animeQueue}
    while read file ; do
        ext=$(echo ${file} | awk -F '.' '{print $NF}')
        ppFile=$(echo ${file} | sed "s/.${ext}/-all.mkv/g")
        grepFilename=$(echo ${file} | sed 's/\[/\\[/g' | sed 's/\]/\\]/g')
        grep -v "${grepFilename}" ${anime} | tee ${anime}
        sed -i '/^$/d' ${anime}
        finalFile=""
        ${qsvAv1} -i "${file}" -a -w ${scratchDir} < /dev/null
        exitCode=$?
        if [ ${exitCode} -ne 0 ]; then
            echo "${file}" | tee -a ${failLog}
            filename=$(echo ${file} | awk -F '/' '{print $NF}')
            dir=$(echo ${file} | sed "s/${filename}//g")
            mkdir -p "${failedDir}/${dir}/"
            mv "${file}" "${failedDir}/${dir}/"
            rm "${ppFile}"
        else
            if [[ "$ext" == "mkv" ]]; then
                finalFile="${file}"
            else
                finalFile=$(echo $ppFile | sed 's/-all.mkv/mkv/g')
            fi
            echo "${file}" | tee -a ${processed}
            mv "${ppFile}" "${file}"
            chgrp jellyfin "${file}"
            chmod 640 "${file}"
            refreshLibrary=1
        fi
    done <<< "$(cat ${anime})"
fi
